{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/tsconfig-holy-grail/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "dependencies": {
        "@types/node": "^22.19.17"
    },
    "description": "This is my personal collection of tsconfig files.",
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-angular": "^21.0.1",
        "chai": "^4.3.10",
        "commitizen": "^4.3.1",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.39.4",
        "eslint-config-holy-grail": "^63.0.1",
        "globals": "^17.6.0",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.4",
        "mocha": "^11.7.5",
        "prettier": "^3.8.3",
        "tsconfig": "^7.0.0",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=22.22.2"
    },
    "files": [
        "src/"
    ],
    "homepage": "https://github.com/chrisguttandin/tsconfig-holy-grail",
    "license": "MIT",
    "name": "tsconfig-holy-grail",
    "peerDependencies": {
        "tslib": "^2.6.1",
        "typescript": "^5.0.4"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/tsconfig-holy-grail.git"
    },
    "scripts": {
        "lint": "npm run lint:config && npm run lint:test",
        "lint:config": "eslint --config config/eslint/config.mjs --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:test": "eslint --config config/eslint/test.mjs --ext .js --report-unused-disable-directives test/",
        "prepare": "husky",
        "test": "npm run lint && npm run test:integration",
        "test:integration": "if [ \"$TYPE\" = \"\" -o \"$TYPE\" = \"integration\" ]; then mocha --bail --parallel --recursive --require config/mocha/config-integration.js test/integration; fi"
    },
    "version": "16.0.0"
}
